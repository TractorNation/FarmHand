{
    "name": "2026 Pit Scouting",
    "sections": [
        {
            "title": "Match Info",
            "fields": [
                {
                    "id": 0,
                    "name": "Match Number",
                    "type": "number",
                    "required": true,
                    "props": {
                        "min": 0,
                        "max": 0,
                        "default": 0,
                        "pullFromTBA": false
                    }
                },
                {
                    "id": 1,
                    "name": "Team Number",
                    "type": "number",
                    "required": true,
                    "props": {
                        "min": 1,
                        "max": 99999,
                        "pullFromTBA": false
                    }
                },
                {
                    "id": 2,
                    "name": "Stock Kit Bot",
                    "type": "checkbox",
                    "required": false,
                    "props": {},
                    "note": "Set True only if OOTB Kit Bot"
                },
                {
                    "id": 3,
                    "name": "Starting Position (Hub POV)",
                    "type": "grid",
                    "required": false,
                    "props": {
                        "rows": 1,
                        "cols": 5
                    },
                    "note": "Hub POV - Left box = Human Player (Corral) side",
                    "doubleWidth": true
                }
            ]
        },
        {
            "title": "Bot Spec",
            "fields": [
                {
                    "id": 1000,
                    "name": "Perimeter (in.))",
                    "type": "number",
                    "required": false,
                    "props": {
                        "min": 80,
                        "max": 150
                    },
                    "note": "WITH Bumpers. If answer does not include bumpers, add 4x bumper width"
                },
                {
                    "id": 1001,
                    "name": "Height (in.)",
                    "type": "number",
                    "required": false,
                    "props": {
                        "min": 0,
                        "max": 30
                    },
                    "note": "30 in. legal max"
                },
                {
                    "id": 1002,
                    "name": "Intake",
                    "type": "dropdown",
                    "required": false,
                    "props": {
                        "options": [
                            "Over Bumper",
                            "Open Bumper"
                        ]
                    }
                },
                {
                    "id": 1003,
                    "name": "Hopper Capacity",
                    "type": "number",
                    "required": false,
                    "props": {
                        "min": 0,
                        "max": 99
                    }
                },
                {
                    "id": 1004,
                    "name": "Hopper Fill Time (s)",
                    "type": "slider",
                    "required": false,
                    "props": {
                        "step": 1,
                        "min": 1,
                        "max": 20,
                        "default": 20
                    },
                    "note": "Seconds to fill Hopper using Intake. Leave default if unknown."
                },
                {
                    "id": 1005,
                    "name": "Volley Time (s)",
                    "type": "slider",
                    "required": false,
                    "props": {
                        "min": 0,
                        "max": 20,
                        "step": 1,
                        "default": 20
                    },
                    "note": "Seconds to empty a full Hopper. Leave default if unknown."
                },
                {
                    "id": 1006,
                    "name": "Scoring Range (ft)",
                    "type": "dropdown",
                    "required": false,
                    "props": {
                        "options": [
                            "N/A (Can't Score)",
                            "1-6 (Hub to Mid)",
                            "7-12 (Tower)",
                            "13-18 (Depot)",
                            "19-Full (Outpost)"
                        ]
                    }
                }
            ]
        },
        {
            "title": "Auto & Climbing",
            "fields": [
                {
                    "id": 2000,
                    "name": "Autonomous",
                    "type": "dropdown",
                    "required": true,
                    "props": {
                        "options": [
                            "None",
                            "Hard-coded",
                            "Path Planner/similar"
                        ]
                    }
                },
                {
                    "id": 2001,
                    "name": "Climb in Auto",
                    "type": "checkbox",
                    "required": false,
                    "props": {}
                },
                {
                    "id": 2002,
                    "name": "Time to Climb (s)",
                    "type": "slider",
                    "required": false,
                    "props": {
                        "selectsRange": true,
                        "min": 0,
                        "max": 30,
                        "step": 1
                    },
                    "note": "Leave as 0-30 if can't climb"
                },
                {
                    "id": 2003,
                    "name": "Climb Position",
                    "type": "grid",
                    "required": false,
                    "props": {
                        "rows": 3,
                        "cols": 3
                    },
                    "note": "Hub POV- rows = rungs, columns = Left/Center/Right. Leave blank if can't climb",
                    "doubleWidth": true
                }
            ]
        },
        {
            "title": "Gameplay",
            "fields": [
                {
                    "id": 3000,
                    "name": "Dump/Transfer Fuel",
                    "type": "dropdown",
                    "required": false,
                    "props": {
                        "options": [
                            "No",
                            "Yes"
                        ]
                    },
                    "note": "Can they distribute fuel to Ally Zone to pick up later?"
                },
                {
                    "id": 3001,
                    "name": "Play Defense?",
                    "type": "slider",
                    "required": false,
                    "props": {
                        "step": 1,
                        "min": 1,
                        "max": 5,
                        "default": 2
                    },
                    "note": "1 = \"Avoids def if possible\", 3 = \"Prefers playing def if possible\""
                },
                {
                    "id": 3002,
                    "name": "AprilTag Use",
                    "type": "dropdown",
                    "required": false,
                    "props": {
                        "options": [
                            "No",
                            "Auto Only",
                            "Yes"
                        ]
                    },
                    "note": "\"Yes\" if used during Teleop, assumed Auto also"
                }
            ]
        },
        {
            "title": "Other",
            "fields": [
                {
                    "id": 4000,
                    "name": "Comments",
                    "type": "text",
                    "required": false,
                    "props": {}
                },
                {
                    "id": 4001,
                    "name": "Vibe Check",
                    "type": "slider",
                    "required": true,
                    "props": {
                        "min": 1,
                        "selectsRange": false,
                        "step": 1,
                        "max": 5,
                        "default": 3
                    },
                    "note": "1 = DNP, 3 = *shrug*, 5 = best friends"
                }
            ]
        }
    ]
}